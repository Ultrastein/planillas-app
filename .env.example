# VITE ENVIRONMENT VARIABLES FOR EDUPLAN PRO

# ==========================================
# 1. SUPABASE CONNECTION (OBLIGATORIO)
# ==========================================
# Reemplaza estas URLs y Keys por las de tu proyecto en Supabase (Settings -> API)
VITE_SUPABASE_URL="https://tu-proyecto.supabase.co"
VITE_SUPABASE_ANON_KEY="tu-anon-key-publica"

# ==========================================
# 2. GOOGLE AUTHENTICATION (OBLIGATORIO)
# ==========================================
# El Client ID de tu proyecto de Google Cloud Console (APIs & Services -> Credentials)
VITE_GOOGLE_CLIENT_ID="tu-client-id-de-google.apps.googleusercontent.com"

# ==========================================
# 3. MODO ADMINISTRADOR (OPCIONAL PERO RECOMENDADO)
# ==========================================
# Service Role Key para operaciones de mantenimiento de usuarios sin restricciones RLS.
# NUNCA expongas esta clave al cliente (el código actual la usa solo bajo ciertas operaciones admin)
VITE_SUPABASE_SERVICE_ROLE_KEY="tu-service-role-key-secreta"
